<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <title>AgriFlow</title>
  <style>
    body { font-family: Arial; background:#f6f6f6; margin:0; }
    header { background:#2e7d32; color:white; padding:20px; }
    .container { padding:20px; }
    .card { background:white; padding:15px; margin:10px 0; border-radius:10px; }
    button { background:#2e7d32; color:white; padding:10px; border:none; border-radius:8px; }
  </style>
</head>
<body>

<header>
  🌾 AgriFlow - Gestion agricole simple
</header>

<div class="container">

  <h2>Dashboard</h2>

  <div class="card">CA du mois : 18 450 €</div>
  <div class="card">Commandes : 73</div>
  <div class="card">Clients actifs : 28</div>
  <div class="card">Factures impayées : 6</div>

  <h2>Actions rapides</h2>

  <button>Nouvelle commande SMS</button>
  <button>Voir clients</button>
  <button>Factures</button>

</div>

</body>
</html>
